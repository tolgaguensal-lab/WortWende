generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(uuid())
  email          String              @unique
  name           String?
  image          String?
  emailVerified  DateTime?
  hashedPassword String?
  role           UserRole            @default(USER)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  accounts       Account[]
  dtzResults     DTZTestResult[]
  reviewItems    ReviewItem[]
  sessions       Session[]
  streaks        Streak[]
  achievements   UserAchievement[]
  answers        UserAnswer[]
  errorProfile   UserErrorProfile[]
  profile        UserProfile?
  progress       UserProgress[]
  skillProgress  UserSkillProgress[]
  xpTransactions XPTransaction[]
  entitlements   Entitlement[]
}

model Entitlement {
  id            String    @id @default(uuid())
  userId        String
  levelCode     CEFRLevel
  grantedAt     DateTime  @default(now())
  expiresAt     DateTime?
  purchaseId    String?
  source        String    // 'PURCHASE', 'SUBSCRIPTION', 'FREE_TIER', 'ADMIN'
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelCode])
}

model Subscription {
  id               String    @id @default(uuid())
  userId           String    @unique
  planId           String    // e.g., 'premium_monthly', 'premium_yearly'
  status           String    // 'active', 'canceled', 'expired'
  startDate        DateTime  @default(now())
  endDate          DateTime
  revenueCatId     String?   // External ID for sync
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id             String                @id @default(uuid())
  userId         String                @unique
  currentLevel   CEFRLevel             @default(A1)
  placementLevel CEFRLevel?
  targetGoal     String?
  totalXp        Int                   @default(0)
  level          Int                   @default(1)
  hearts         Int                   @default(5)
  maxHearts      Int                   @default(5)
  streak         Int                   @default(0)
  longestStreak  Int                   @default(0)
  dailyGoal      Int                   @default(50)
  lastActiveAt   DateTime?
  preferredTheme String                @default("system")
  nativeLanguage String                @default("en")
  avatarUrl      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  placementTests PlacementTestResult[]
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String    @id @default(uuid())
  name        String
  description String
  level       CEFRLevel
  imageUrl    String?
  order       Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  units       Unit[]
}

model Unit {
  id          String   @id @default(uuid())
  courseId    String
  name        String
  description String
  order       Int
  themeColor  String?
  iconUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id                 String              @id @default(uuid())
  unitId             String
  name               String
  description        String
  learningObjective  String?
  lifeSituationId    String?
  skillCategory      SkillCategory?
  order              Int
  xpReward           Int                 @default(10)
  isLocked           Boolean             @default(true)
  isPublished        Boolean             @default(false)
  requiredXp         Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  exercises          Exercise[]
  learningObjectives LearningObjective[]
  lifeSituation      LifeSituation?      @relation(fields: [lifeSituationId], references: [id])
  unit               Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lessonSteps        LessonStep[]
  progress           UserProgress[]
}

model Vocabulary {
  id                 String           @id @default(uuid())
  word               String
  article            String?
  plural             String?
  pos                String
  level              CEFRLevel
  gender             Gender?
  baseForm           String?
  conjugationJson    String?
  steigerungJson     String?
  translationEn      String
  translationTr      String?
  translationRu      String?
  translationAr      String?
  translationPl      String?
  translationRo      String?
  translationUk      String?
  translationSq      String?
  translationKu      String?
  translationIt      String?
  exampleSentence    String?
  exampleTranslation String?
  audioUrl           String?
  sourceName         String?
  sourceUrl          String?
  license            String?
  attribution        String?
  importedAt         DateTime?        @default(now())
  reviewedByAdmin    Boolean          @default(false)
  isPublished        Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  lifeSituationId    String?
  exerciseOptions    ExerciseOption[]
  reviewItems        ReviewItem[]
  lifeSituation      LifeSituation?   @relation(fields: [lifeSituationId], references: [id])
}

model GrammarTopic {
  id              String         @id @default(uuid())
  name            String
  description     String
  level           CEFRLevel
  explanation     String
  examples        String
  tips            String?
  order           Int
  sourceName      String?
  sourceUrl       String?
  license         String?
  attribution     String?
  importedAt      DateTime?      @default(now())
  reviewedByAdmin Boolean        @default(false)
  isPublished     Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  lifeSituationId String?
  lifeSituation   LifeSituation? @relation(fields: [lifeSituationId], references: [id])
}

model Sentence {
  id              String    @id @default(uuid())
  text            String
  translationEn   String
  translationDe   String?
  level           CEFRLevel
  audioUrl        String?
  sourceName      String?
  sourceUrl       String?
  license         String?
  attribution     String?
  importedAt      DateTime? @default(now())
  reviewedByAdmin Boolean   @default(false)
  isPublished     Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Exercise {
  id            String           @id @default(uuid())
  lessonId      String
  type          ExerciseType
  question      String
  content       String
  correctAnswer String
  explanation   String?
  xpValue       Int              @default(5)
  difficulty    DifficultyLevel  @default(EASY)
  order         Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lesson        Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options       ExerciseOption[]
  userAnswers   UserAnswer[]
}

model ExerciseOption {
  id           String      @id @default(uuid())
  exerciseId   String
  text         String
  isCorrect    Boolean     @default(false)
  order        Int
  vocabularyId String?
  exercise     Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  vocabulary   Vocabulary? @relation(fields: [vocabularyId], references: [id])
}

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  score       Int       @default(0)
  xpEarned    Int       @default(0)
  timeSpent   Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model UserAnswer {
  id         String   @id @default(uuid())
  userId     String
  exerciseId String
  answer     String
  isCorrect  Boolean
  timeSpent  Int
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReviewItem {
  id           String      @id @default(uuid())
  userId       String
  vocabularyId String?
  easeFactor   Float       @default(2.5)
  interval     Int         @default(1)
  repetitions  Int         @default(0)
  nextReview   DateTime
  lastReview   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary   Vocabulary? @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextReview])
}

model Achievement {
  id          String            @id @default(uuid())
  name        String
  description String
  iconUrl     String?
  category    String
  requirement Int
  xpReward    Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model Streak {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime
  completedGoal Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model XPTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  source    String
  sourceId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model APIImportSource {
  id            String    @id @default(uuid())
  name          String
  url           String
  lastImportAt  DateTime?
  totalImported Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ContentAttribution {
  id          String   @id @default(uuid())
  sourceName  String
  sourceUrl   String
  license     String
  attribution String
  contentType String
  contentId   String
  createdAt   DateTime @default(now())
}

model AdminContentReview {
  id          String    @id @default(uuid())
  contentType String
  contentId   String
  reviewerId  String
  status      String    @default("pending")
  notes       String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model LifeSituation {
  id            String                @id @default(uuid())
  name          String
  description   String?
  category      LifeSituationCategory
  iconUrl       String?
  order         Int
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  grammarTopics GrammarTopic[]
  lessons       Lesson[]
  vocabularies  Vocabulary[]
}

model LearningObjective {
  id              String        @id @default(uuid())
  lessonId        String
  title           String
  description     String?
  lifeSituationId String?
  cefrLevel       CEFRLevel
  skillCategory   SkillCategory
  order           Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lesson          Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonStep {
  id        String         @id @default(uuid())
  lessonId  String
  stepType  LessonStepType
  title     String
  content   String
  order     Int
  xpReward  Int            @default(5)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Translation {
  id              String   @id @default(uuid())
  sourceText      String
  sourceLang      String
  targetLang      String
  translatedText  String
  provider        String
  glossaryId      String?
  reviewedByAdmin Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model TranslationProvider {
  id         String       @id @default(uuid())
  name       String
  type       ProviderType
  apiKey     String?
  endpoint   String?
  isActive   Boolean      @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model GlossaryTerm {
  id              String     @id @default(uuid())
  term            String
  sourceLang      String
  targetLang      String
  translation     String
  context         String?
  level           CEFRLevel?
  reviewedByAdmin Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model PlacementTest {
  id          String                @id @default(uuid())
  title       String
  description String?
  cefrLevel   CEFRLevel
  questions   String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  results     PlacementTestResult[]
}

model PlacementTestResult {
  id          String        @id @default(uuid())
  userId      String
  testId      String
  score       Int
  level       CEFRLevel
  completedAt DateTime      @default(now())
  test        PlacementTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        UserProfile   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
}

model UserSkillProgress {
  id              String        @id @default(uuid())
  userId          String
  skillCategory   SkillCategory
  cefrLevel       CEFRLevel
  correctAnswers  Int           @default(0)
  totalAttempts   Int           @default(0)
  lastPracticedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillCategory, cefrLevel])
}

model UserErrorProfile {
  id             String     @id @default(uuid())
  userId         String
  errorType      String
  errorMessage   String?
  grammarTopic   String?
  cefrLevel      CEFRLevel?
  occurrences    Int        @default(1)
  lastOccurredAt DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── KI-Tutor Rate Limiting ──────────────────────────────────────────────────

model TutorRequestLog {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ReviewQueue {
  id          String       @id @default(uuid())
  contentType String
  contentId   String
  status      ReviewStatus @default(PENDING)
  reviewerId  String?
  notes       String?
  createdAt   DateTime     @default(now())
  reviewedAt  DateTime?
}

model ApiKey {
  id         String          @id @default(uuid())
  name       String
  keyPrefix  String
  keyHash    String          @unique
  userId     String?
  scopes     String          @default("read")
  rateLimit  Int             @default(100)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  requests   ApiRequestLog[]
}

model DTZTest {
  id        String          @id @default(uuid())
  name      String
  level     CEFRLevel
  skill     SkillCategory
  questions String
  timeLimit Int
  xpReward  Int             @default(50)
  isActive  Boolean         @default(true)
  order     Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  results   DTZTestResult[]
}

model DTZTestResult {
  id          String   @id @default(uuid())
  userId      String
  testId      String
  score       Int
  passed      Boolean
  timeSpent   Int
  completedAt DateTime @default(now())
  feedback    String?
  test        DTZTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, testId])
  @@index([userId])
  @@index([completedAt])
}

model ApiRequestLog {
  id         String   @id @default(uuid())
  apiKeyId   String
  endpoint   String
  method     String
  statusCode Int
  ip         String?
  userAgent  String?
  duration   Int?
  createdAt  DateTime @default(now())
  apiKey     ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  SENTENCE_ORDER
  TRANSLATION
  LISTENING
  WORD_IMAGE
  ARTICLE_TRAINING
  VERB_CONJUGATION
  DATIVE_ACCUSATIVE
  WRITING
  PRONUNCIATION
  DIALOGUE
  WORD_MEMORY
  ARTICLE_BATTLE
  GRAMMAR_DUEL
  ERROR_FINDER
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum Gender {
  MASCULINE
  FEMININE
  NEUTER
}

enum LifeSituationCategory {
  ARBEIT
  WOHNEN
  EINKAUFEN
  GESUNDHEIT
  BILDUNG
  BEHOERDEN
  MEDIEN
  VERKEHR
  FREIZEIT
  BANK
  VERSICHERUNG
  KINDER
}

enum SkillCategory {
  LESEN
  HOEREN
  SCHREIBEN
  SPRECHEN
  GRAMMATIK
  WORTSCHATZ
}

enum LessonStepType {
  WORTSCHATZ
  GRAMMATIK
  HOEREN
  LESEN
  SCHREIBEN
  SPRECHEN
  MINI_GAME
  TEST
  WIEDERHOLUNG
}

enum ProviderType {
  DEEPL
  GOOGLE
  AZURE
  LIBRETRANSLATE
  MOCK
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
